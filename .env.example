# PostgreSQL settings
POSTGRES_SERVER=localhost      # PostgreSQL server hostname
POSTGRES_PORT=5432           # PostgreSQL server port
POSTGRES_USER=postgres       # PostgreSQL username
POSTGRES_PASSWORD=postgres   # PostgreSQL password
POSTGRES_DB=url_shortener   # PostgreSQL database name
POSTGRES_SSL_MODE=prefer    # SSL mode: disable, allow, prefer, require, verify-ca, verify-full

# Redis settings
REDIS_HOST=localhost        # Redis server hostname
REDIS_PORT=6379           # Redis server port
REDIS_PASSWORD=           # Redis password (leave empty if no password)
REDIS_SSL=false          # Enable SSL for Redis connection
REDIS_DB=0              # Redis database number (0-15)

# JWT settings
SECRET_KEY=your-secret-key-here    # Secret key for JWT token generation
ALGORITHM=HS256                   # JWT algorithm
ACCESS_TOKEN_EXPIRE_MINUTES=30    # JWT token expiration time in minutes

# Application settings
PUBLIC_PROJECT_LINK_EXPIRY_DAYS=5  # Number of days before public project links expire

# Testing mode
TESTING=true           # Set to true to use SQLite for testing or false to use PostgreSQL